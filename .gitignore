# Build outputs
build/
Debug/
.pio/
.platformio-home/
$PROJECT_BUILD_DIR/

# Editor and local tool state
.vscode/ipch/
.idea/
.claude/

# Python cache and local environments
__pycache__/
*.py[cod]
.venv/
venv/

# Embedded build artifacts
*.bin
*.elf
*.map
*.o
*.d
*.a
*.out

# Archives and generated reports
*.zip
*.rar
*.7z

# Logs
logs/
*.log

# Keep K230 experiment logs visible in VS Code so selected runs can be shared.
!k230-pid-gimbal/host/
!k230-pid-gimbal/host/logs/
!k230-pid-gimbal/host/logs/**
!k230-pid-gimbal/host/logs/**/*.log

# Keep MSPM0 PID host-tuning logs visible in VS Code.
!mspm0-pid-car/pid-lab/HOST/
!mspm0-pid-car/pid-lab/HOST/logs/
!mspm0-pid-car/pid-lab/HOST/logs/**
!mspm0-pid-car/pid-lab/HOST/logs/**/*.log

# Ignore generated MSPM0 tuning sessions; add a specific useful trace with -f.
mspm0-pid-car/pid-lab/HOST/logs/20*/
mspm0-pid-car/pid-lab/HOST/logs/line_20*/
mspm0-pid-car/pid-lab/HOST/logs/square_20*/
mspm0-pid-car/pid-lab/HOST/logs/straight_20*/
mspm0-pid-car/pid-lab/tmp/
